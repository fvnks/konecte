# Google Sheets Config
GOOGLE_SHEETS_ID=your_sheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email
GOOGLE_PRIVATE_KEY="your_private_key_json_string_escaped_or_base64"

# API Configuration
GEMINI_API_KEY=your_gemini_api_key

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=whatsapp_bot_db
DB_USER=root
DB_PASSWORD=your_password

# Server Configuration
PORT=7000
NODE_ENV=development

# JWT Configuration
# JWT_SECRET=your_very_strong_jwt_secret
# JWT_EXPIRES_IN=24h

# WhatsApp Configuration
ENABLE_WHATSAPP=true

# Encryption Key
# APP_ENCRYPTION_KEY=your_32_character_long_encryption_key

# Logging Configuration
LOG_LEVEL=info
ENABLE_FILE_LOGGING=true

# Google API Credentials (Formato alternativo si GOOGLE_PRIVATE_KEY es problemático)
# GOOGLE_API_CREDENTIALS='{"type": "service_account", ...}' 